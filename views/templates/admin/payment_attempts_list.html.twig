{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="row">
    <div class="col-12">
        <div class="card">
            <h3 class="card-header">
                <i class="material-icons">payment</i>
                {{ 'Maksuturva Payment Attempts'|trans({}, 'Modules.Maksuturva.Admin') }}
            </h3>

            <div class="card-body">
                {# Filter Form #}
                <form method="get" action="{{ path('maksuturva_payment_attempts') }}" class="mb-4">
                    <input type="hidden" name="_token" value="{{ csrf_token }}" size=200  />
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>{{ 'Cart ID'|trans({}, 'Modules.Maksuturva.Admin') }}</label>
                                <input type="number" name="cart_id" class="form-control" value="{{ filters.cart_id }}">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>{{ 'Order ID'|trans({}, 'Modules.Maksuturva.Admin') }}</label>
                                <input type="number" name="order_id" class="form-control" value="{{ filters.order_id }}">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>{{ 'Payment ID'|trans({}, 'Modules.Maksuturva.Admin') }}</label>
                                <input type="text" name="pmt_id" class="form-control" value="{{ filters.pmt_id }}">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>{{ 'Status'|trans({}, 'Modules.Maksuturva.Admin') }}</label>
                                <select name="status" class="form-control">
                                    {% for value, label in statusOptions %}
                                        <option value="{{ value }}" {% if filters.status == value %}selected{% endif %}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>{{ 'Date From'|trans({}, 'Modules.Maksuturva.Admin') }}</label>
                                <input type="date" name="date_from" class="form-control" value="{{ filters.date_from }}">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>{{ 'Date To'|trans({}, 'Modules.Maksuturva.Admin') }}</label>
                                <input type="date" name="date_to" class="form-control" value="{{ filters.date_to }}">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="material-icons">search</i>
                                {{ 'Search'|trans({}, 'Admin.Actions') }}
                            </button>
                            <a href="{{ path('maksuturva_payment_attempts') }}" class="btn btn-secondary">
                                <i class="material-icons">refresh</i>
                                {{ 'Reset'|trans({}, 'Admin.Actions') }}
                            </a>
                        </div>
                    </div>
                </form>

                {# Results Table #}
                {% if payments|length > 0 %}
                    <div class="mb-3">
                        <small class="text-muted">
                            {{ 'Showing %from% to %to% of %total% entries'|trans({
                                '%from%': ((pagination.current_page - 1) * pagination.page_size) + 1,
                                '%to%': min(pagination.current_page * pagination.page_size, pagination.total_records),
                                '%total%': pagination.total_records
                            }, 'Admin.Global') }}
                        </small>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>{{ 'ID'|trans({}, 'Admin.Global') }}</th>
                                    <th>{{ 'Cart ID'|trans({}, 'Modules.Maksuturva.Admin') }}</th>
                                    <th>{{ 'Order ID'|trans({}, 'Modules.Maksuturva.Admin') }}</th>
                                    <th>{{ 'Attempt'|trans({}, 'Modules.Maksuturva.Admin') }}</th>
                                    <th>{{ 'Payment ID'|trans({}, 'Modules.Maksuturva.Admin') }}</th>
                                    <th>{{ 'Status'|trans({}, 'Admin.Global') }}</th>
                                    <th>{{ 'Created'|trans({}, 'Admin.Global') }}</th>
                                    <th>{{ 'Actions'|trans({}, 'Admin.Global') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for payment in payments %}
                                    <tr>
                                        <td>{{ payment.id }}</td>
                                        <td>
                                            {% if payment.cart_id > 0 %}
                                                <a href="{{ path('admin_carts_view', {cartId: payment.cart_id}) }}" target="_blank">
                                                    {{ payment.cart_id }}
                                                </a>
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if payment.order_id > 0 %}
                                                <a href="{{ path('admin_orders_view', {orderId: payment.order_id}) }}" target="_blank">
                                                    {{ payment.order_id }}
                                                </a>
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td>#{{ payment.attempt }}</td>
                                        <td>{{ payment.pmt_id }}</td>
                                        <td><span class="badge badge-secondary">{{ payment.status }}</span></td>
                                        <td>{{ payment.date_add }}</td>
                                        <td>
                                            <a href="{{ path('maksuturva_payment_attempt_view', {id: payment.id}) }}" class="btn btn-sm btn-primary">
                                                <i class="material-icons">visibility</i>
                                                {{ 'View'|trans({}, 'Admin.Actions') }}
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {# Pagination #}
                    {% if pagination.total_pages > 1 %}
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                {# Previous #}
                                <li class="page-item {% if pagination.current_page == 1 %}disabled{% endif %}">
                                    <a class="page-link" href="{{ path('maksuturva_payment_attempts', filters|merge({page: pagination.current_page - 1})) }}" aria-label="{{ 'Previous'|trans({}, 'Admin.Global') }}">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                </li>

                                {# First page #}
                                {% if pagination.current_page > 3 %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('maksuturva_payment_attempts', filters|merge({page: 1})) }}">1</a>
                                    </li>
                                    {% if pagination.current_page > 4 %}
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    {% endif %}
                                {% endif %}

                                {# Page numbers #}
                                {% for page in range(max(1, pagination.current_page - 2), min(pagination.total_pages, pagination.current_page + 2)) %}
                                    <li class="page-item {% if page == pagination.current_page %}active{% endif %}">
                                        <a class="page-link" href="{{ path('maksuturva_payment_attempts', filters|merge({page: page})) }}">{{ page }}</a>
                                    </li>
                                {% endfor %}

                                {# Last page #}
                                {% if pagination.current_page < pagination.total_pages - 2 %}
                                    {% if pagination.current_page < pagination.total_pages - 3 %}
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    {% endif %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('maksuturva_payment_attempts', filters|merge({page: pagination.total_pages})) }}">{{ pagination.total_pages }}</a>
                                    </li>
                                {% endif %}

                                {# Next #}
                                <li class="page-item {% if pagination.current_page == pagination.total_pages %}disabled{% endif %}">
                                    <a class="page-link" href="{{ path('maksuturva_payment_attempts', filters|merge({page: pagination.current_page + 1})) }}" aria-label="{{ 'Next'|trans({}, 'Admin.Global') }}">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                {% else %}
                    <div class="alert alert-info">
                        <i class="material-icons">info</i>
                        {{ 'No payment attempts found'|trans({}, 'Modules.Maksuturva.Admin') }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
